APP_NAME="ChatFlow CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chatflow_crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
# Produção recomendada: SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Produção recomendada: QUEUE_CONNECTION=redis

# Reverb (tempo real) — ative quando for usar Echo no painel
REVERB_APP_ID=mgi-chat
REVERB_APP_KEY=mgi-local-key
REVERB_APP_SECRET=mgi-local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# Produção recomendada: CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Após instalar Redis, use session/queue/cache=redis para tirar carga do MySQL.

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CHATFLOW_NAME="MGI chat"
CHATFLOW_PRIMARY_COLOR="#8B1E3F"

WHATSAPP_DRIVER=null

# Meta Cloud API — também configurável em Configurações → WhatsApp Meta
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=chatflow_webhook_secret

# URL pública do sistema (obrigatório HTTPS para webhook Meta)
APP_URL=http://127.0.0.1:8000

# Evolution API (WHATSAPP_DRIVER=evolution)
WHATSAPP_EVOLUTION_URL=http://localhost:8080
WHATSAPP_EVOLUTION_API_KEY=
WHATSAPP_EVOLUTION_INSTANCE=chatflow

# Bot automático
BOT_ENABLED=true
BOT_NAME="Assistente ChatFlow"
BOT_AUTO_ESCALATE=true
